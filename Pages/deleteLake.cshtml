@page
@model deleteLakeModel
@{
    ViewData["Title"] = "Delete Lake";
}
<h1>Delete Lake</h1>
<p>Are you sure you want to delete this lake?</p>
<form method="post">
    <input type="hidden" asp-for="NewLake.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="/Index" class="btn btn-secondary">Cancel</a>
</form> 